generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CLIENTES - Empresas que contratan MyCompi
// ============================================
model Cliente {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  email       String   @unique
  plan        Plan     @default(BASICO)
  logo        String?
  webUrl      String?
  stripeCustomerId String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios    Usuario[]
  agentes     Agente[]
  trabajos    Trabajo[]
  pagos       Pago[]
  documentos  Documento[]
  interacciones InteraccionChat[]
  emails        Email[]
  notificaciones Notificacion[]
}

// ============================================
// USUARIOS - Users de cada cliente
// ============================================
model Usuario {
  id            String   @id @default(cuid())
  clienteId     String
  nombre        String
  email         String   @unique
  passwordHash  String
  rol           Rol      @default(USUARIO)
  rol_platform  RolPlatform @default(CLIENT)
  idioma        String    @default("es")
  timezone      String    @default("Europe/Madrid")
  ultimoAcceso  DateTime?
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cliente       Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

// ============================================
// AGENTES - Trabajadores digitales (Alex, Mia...)
// ============================================
model Agente {
  id          String   @id @default(cuid())
  clienteId   String
  workerId    String   @unique  // worker_dev_01_alex, worker_mkt_02_mia
  nombre      String
  email       String   @unique  // alex.rivera@mycompi.com
  tipo        TipoAgente
  personalidad String?
  bio         String?
  birthday    DateTime?
  habilidades String[]
  modelId     String   @default("minimax/MiniMax-M2.7")
  config      Json?
  estado      EstadoAgente @default(ACTIVO)
  horario     Json?    // { "inicio": "10:00", "fin": "19:00", "tz": "Europe/Madrid" }
  memory      Json?    // memoria largo plazo
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  trabajos    Trabajo[]
  mensajes    Mensaje[]
  interacciones InteraccionChat[]
}

// ============================================
// TRABAJOS - Tareas/historial
// ============================================
model Trabajo {
  id          String   @id @default(cuid())
  clienteId   String
  agenteId    String
  titulo      String
  descripcion String?
  estado      EstadoTrabajo @default(TODO)
  prioridad   Prioridad @default(MEDIA)
  tags        String[]
  inputData   Json?
  outputData  Json?
  errorMsg    String?
  estimatedHours Float?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agente      Agente   @relation(fields: [agenteId], references: [id], onDelete: Cascade)
}

// ============================================
// PAGOS - Suscripciones
// ============================================
model Pago {
  id              String   @id @default(cuid())
  clienteId       String
  stripePaymentId String?
  cantidad        Float
  moneda          String   @default("EUR")
  estado          EstadoPago
  tipo            TipoPago
  descripcion     String?
  fechaPago       DateTime @default(now())
  createdAt       DateTime  @default(now())

  cliente         Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

// ============================================
// DOCUMENTOS - Memoria y docs de empresa
// ============================================
model Documento {
  id          String   @id @default(cuid())
  clienteId   String
  tipo        TipoDocumento
  titulo      String
  contenido   String
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

// ============================================
// MENSAJES - Mensajes internos agente a agente
// ============================================
model Mensaje {
  id        String   @id @default(cuid())
  agenteId  String
  paraAgenteId String?
  contenido String
  tipo      TipoMensaje @default(MENSAJE)
  metadata  Json?
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  agente    Agente   @relation(fields: [agenteId], references: [id], onDelete: Cascade)
}


// ============================================
// NOTIFICACIONES PROACTIVAS — agentes avisan al cliente
// ============================================
model Notificacion {
  id          String   @id @default(cuid())
  clienteId   String
  agenteId    String
  tipo        TipoNotificacion @default(INFO)
  titulo      String
  contenido   String   @db.Text
  leida       Boolean  @default(false)
  createdAt   DateTime @default(now())

  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

enum TipoNotificacion {
  INFO
  ALERTA
  ACCION_REQUERIDA
  COMPLETADO
}

enum TipoPeticion {
  CREAR_CONTENIDO
  CONSULTAR_INFO
  MODIFICAR_SOLICITUD
  QUEJA
  ALERTA
  OTRO
}

// ============================================
// EMAILS — Bandeja de entrada de Paco
// ============================================
model Email {
  id             String      @id @default(cuid())
  messageId      String?     // ID de Resend para tracking
  de             String      // email del remitente
  para           String      // paco@mycompi.com
  asunto         String      @db.VarChar(500)
  texto          String      @db.Text
  html           String?     @db.Text
  raw            String?     @db.Text  // raw MIME
  EstadoEmail    EstadoEmail @default(RECIBIDO)
  clienteId      String?     // si se identifica al cliente
  interaccionId  String?     // linked InteraccionChat si se creó desde chat
  respuestaA     String?     @default(cuid())  // ID del email al que responde
  agenteId      String?     @default("paco")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  cliente        Cliente?    @relation(fields: [clienteId], references: [id])
}

enum EstadoEmail {
  RECIBIDO
  PROCESANDO
  RESPONDIDO
  FALLIDO
}

// ============================================
// INTERACCIONES DE CHAT (aprendizaje)
// ============================================
model InteraccionChat {
  id               String   @id @default(cuid())
  clienteId        String
  agenteId         String
  tipoPeticion     TipoPeticion
  mensajeOriginal  String   @db.Text
  resumen         String?  @db.VarChar(250)
  respuestaAgente  String? @db.Text
  estadoChat       EstadoChat @default(PENDING)
  streamId         String?
  clienteAcepta   Boolean?
  resultadoExitoso Boolean?
  createdAt       DateTime @default(now())

  cliente         Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agente          Agente  @relation(fields: [agenteId], references: [id], onDelete: Cascade)
}

// ============================================
// ENUMS
// ============================================
enum Plan {
  BASICO
  EQUIPO
  DIRECCION
  COMPLETO
}

enum Rol {
  OWNER
  USUARIO
  VIEWER
}

enum RolPlatform {
  ADMIN
  CLIENT
}

enum TipoAgente {
  ENGINEERING
  MARKETING
  SALES
  SUPPORT
  DATA
  RESEARCH
  CONTENT
  CEO
}

enum EstadoAgente {
  ACTIVO
  DESCANSANDO
  OFFLINE
}

enum EstadoChat {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EstadoTrabajo {
  TODO
  IN_PROGRESS
  COMPLETED
  FAILED
  BLOCKED
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum EstadoPago {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TipoPago {
  SUSCRIPCION
  EXTRA
  META_ADS
}

enum TipoDocumento {
  MISION
  PRODUCTO
  BRAND_VOICE
  USER_RESEARCH
  TECNICO
  MEMORIA_AGENTE
}

enum TipoMensaje {
  MENSAJE
  ALERTA
  REPORTE
  SOLICITUD
}
